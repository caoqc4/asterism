# Copy to .env for local alpha validation.
# Shell environment variables override values from this file.

# Options: anthropic, openai, openai-compatible, fal-openrouter, replicate
TASKPLANE_AI_PROVIDER=replicate

# Replicate native example. Use a text model slug from Replicate.
# fal-openrouter example: google/gemini-2.5-flash
# openai-compatible example: use the model id expected by your relay.
TASKPLANE_AI_MODEL=openai/gpt-oss-20b

# Leave empty for replicate to use https://api.replicate.com/v1.
# Leave empty for fal-openrouter to use https://fal.run/openrouter/router/openai/v1.
# Set for generic OpenAI-compatible relays, for example https://your-relay.example.com/v1.
TASKPLANE_AI_BASE_URL=

# Test key only. Do not commit real keys.
TASKPLANE_AI_API_KEY=replace-with-your-test-key

# Optional. Used only by explicitly opted-in read-only workspace agent runs.
TASKPLANE_WORKSPACE_ROOT=/absolute/path/to/your/workspace

TASKPLANE_ENABLE_SCHEDULER=false

# Keep false for normal text-only validation.
# Set true for anthropic/openai/openai-compatible/fal-openrouter provider-native tool-call validation.
TASKPLANE_ENABLE_PROVIDER_NATIVE_TOOL_CALLS=false

# Optional macOS release signing/notarization preflight values.
# These are only needed before a dedicated signed/notarized release pass.
# Keep empty for normal local development and unsigned smoke checks.
CSC_NAME=
CSC_LINK=
CSC_KEY_PASSWORD=
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=
