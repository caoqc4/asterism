{
  "name": "taskplane",
  "productName": "Taskplane",
  "version": "0.1.0",
  "private": true,
  "description": "A local-first desktop workbench for tasks, decisions, runs, and briefs.",
  "author": "Taskplane contributors",
  "type": "module",
  "main": "dist-electron/main/bootstrap.cjs",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main/index.js && node scripts/sync-main-assets.mjs && cross-env ELECTRON_RUN_AS_NODE= VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "node -e \"fs.rmSync('dist-electron', { recursive: true, force: true })\" && tsc -p tsconfig.electron.json && node scripts/sync-main-assets.mjs",
    "rebuild:node": "npm rebuild better-sqlite3 keytar",
    "rebuild:electron": "electron-rebuild --force --module-dir . --which-module better-sqlite3 --build-from-source",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "test": "vitest run",
    "accept:agent-local": "npm run accept:workspace-patch && npm run accept:domain-agent-tools && npm run accept:provider-native-tools && npm run accept:sandbox-coding",
    "accept:workspace-patch": "vitest run src/main/domain/decision/decision-service.integration.test.ts -t \"approves a workspace patch checkpoint\"",
    "accept:domain-agent-tools": "vitest run src/main/domain/run/agent-tool-registry.integration.test.ts",
    "accept:provider-native-tools": "vitest run src/shared/openai-compatible-tool-call-adapter.test.ts src/shared/anthropic-tool-use-adapter.test.ts src/shared/provider-native-tool-call-adapter.test.ts src/shared/provider-tool-call-normalizer.test.ts src/main/domain/run/provider-native-tool-schema.test.ts src/main/domain/run/provider-native-session-gate.test.ts src/main/domain/run/agent-run-loop.test.ts src/main/domain/run/run-orchestrator.test.ts src/main/domain/run/run-service.integration.test.ts src/main/executors/ai-client.test.ts src/main/executors/provider-native-live-validate.test.ts src/main/executors/text-generation.test.ts",
    "accept:sandbox-coding": "vitest run src/shared/agent-sandbox-provider.test.ts src/shared/agent-session-metadata.test.ts src/renderer/lib/agentCapabilities.test.ts src/main/domain/run/temp-workspace-sandbox-provider.test.ts src/main/domain/run/local-container-sandbox-backend.test.ts src/main/domain/run/sandbox-patch-draft-source.test.ts src/main/domain/run/sandboxed-coding-producer.test.ts src/main/domain/run/sandboxed-coding-producer.integration.test.ts src/main/domain/run/sandboxed-coding-staged-patch.test.ts src/main/domain/run/sandbox-patch-review-request.test.ts src/main/domain/run/sandbox-patch-review-run-plan.test.ts src/main/domain/run/sandbox-patch-review-planning-service.test.ts src/main/domain/run/sandbox-patch-review-persister.test.ts src/main/domain/run/sandbox-patch-review-persister.integration.test.ts src/main/domain/run/sandbox-patch-review-run-adapter.test.ts src/main/domain/run/sandbox-patch-review-run-adapter.integration.test.ts src/main/domain/run/sandbox-patch-review-service-factory.test.ts src/main/domain/run/run-orchestrator.test.ts",
    "accept:provider-native-live:preflight": "node scripts/provider-native-live-preflight.mjs",
    "accept:provider-native-live": "node scripts/provider-native-live-validate.mjs",
    "accept:provider-native-live:run": "vitest run --config vitest.live.config.ts scripts/provider-native-run-live.test.ts",
    "verify": "npm run test && npm run lint && npm run build",
    "smoke:build": "npm run build && node scripts/smoke-build.mjs",
    "smoke:package:mac": "node scripts/smoke-package-mac.mjs",
    "smoke:runtime:mac": "node scripts/smoke-runtime-mac.mjs",
    "smoke:release:mac": "npm run dist:mac:dir && npm run smoke:package:mac && npm run smoke:runtime:mac",
    "release:mac:preflight": "node scripts/release-mac-preflight.mjs",
    "dist:mac:dir": "npm run build && npm run rebuild:electron && node node_modules/electron-builder/cli.js --mac dir && npm run rebuild:node",
    "dist:mac": "npm run build && npm run rebuild:electron && node node_modules/electron-builder/cli.js --mac && npm run rebuild:node"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@types/better-sqlite3": "^7.6.13",
    "ai": "^6.0.168",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "keytar": "^7.9.0",
    "node-cron": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.2.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.2",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vitest": "^4.1.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.taskplane.app",
    "productName": "Taskplane",
    "directories": {
      "buildResources": "build-resources",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
